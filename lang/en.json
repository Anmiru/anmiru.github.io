  "aninfo-title-mizu_zokusei_no_mahoutsukai": "Mizu Zokusei no Mahoutsukai",
  "aninfo-genre-mizu_zokusei_no_mahoutsukai": "Ação, Fantasia",
  "aninfo-status-mizu_zokusei_no_mahoutsukai": "Complete",
  "aninfo-episodes-mizu_zokusei_no_mahoutsukai": "12",
